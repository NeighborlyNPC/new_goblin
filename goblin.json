		"events": {

			"minecraft:entity_spawned": {
				"trigger": { "event": "loot:on_spawned" }
			},

			"loot:on_spawned": {
				"sequence": [
					{ "add": { "component_groups": [ "loot:spawning", "loot:stage_0" ] } },
					{
						"randomize": [
							{
								"weight": 20,
								"sequence": [
									{ "add": { "component_groups": [ "loot:combat_melee_sword" ] } },
									{ "set_property": { "loot:weapon_state": 1, "loot:weapon_texture": 1, "loot:weapon_tier": 1 } }
								]
							},
							{
								"weight": 15,
								"sequence": [
									{ "add": { "component_groups": [ "loot:combat_melee_axe" ] } },
									{ "set_property": { "loot:weapon_state": 5, "loot:weapon_texture": 3, "loot:weapon_tier": 1 } }
								]
							},
							{
								"weight": 15,
								"sequence": [
									{ "add": { "component_groups": [ "loot:combat_melee_spear" ] } },
									{ "set_property": { "loot:weapon_state": 4, "loot:weapon_texture": 7, "loot:weapon_tier": 1 } }
								]
							},
							{
								"weight": 5,
								"sequence": [
									{ "add": { "component_groups": [ "loot:combat_melee_mace" ] } },
									{ "set_property": { "loot:weapon_state": 3, "loot:weapon_texture": 0, "loot:weapon_tier": 1 } }
								]
							},
							{
								"weight": 25,
								"sequence": [
									{ "add": { "component_groups": [ "loot:combat_ranged" ] } },
									{ "set_property": { "loot:weapon_state": 2, "loot:weapon_texture": 0, "loot:weapon_tier": 0 } }
								]
							},
							{
								"weight": 20,
								"sequence": [
									{ "add": { "component_groups": [ "loot:combat_melee_unarmed" ] } },
									{ "set_property": { "loot:weapon_state": 0, "loot:weapon_texture": 0, "loot:weapon_tier": 0 } }
								]
							}
						]
					}
				]
			},

			"loot:finish_spawn": {
				"sequence": [
					{ "remove": { "component_groups": [ "loot:spawning" ] } },
					{ "add":    { "component_groups": [ "loot:wild" ] } }
				]
			},

			"loot:on_tamed": {
				"sequence": [
					{ "remove": { "component_groups": [ "loot:wild" ] } },
					{ "add":    { "component_groups": [ "loot:tamed" ] } },
					{ "set_property": { "loot:tamed": true } },
					{ "trigger": { "event": "loot:unlock_movement" } }
				]
			},

			"loot:set_stage_0": {
				"sequence": [
					{ "remove": { "component_groups": [ "loot:stage_1", "loot:stage_2", "loot:stage_3" ] } },
					{ "add":    { "component_groups": [ "loot:stage_0" ] } },
					{ "set_property": { "loot:stage": 0 } }
				]
			},
			"loot:set_stage_1": {
				"sequence": [
					{ "remove": { "component_groups": [ "loot:stage_0", "loot:stage_2", "loot:stage_3" ] } },
					{ "add":    { "component_groups": [ "loot:stage_1" ] } },
					{ "set_property": { "loot:stage": 1 } }
				]
			},
			"loot:set_stage_2": {
				"sequence": [
					{ "remove": { "component_groups": [ "loot:stage_0", "loot:stage_1", "loot:stage_3" ] } },
					{ "add":    { "component_groups": [ "loot:stage_2" ] } },
					{ "set_property": { "loot:stage": 2 } }
				]
			},
			"loot:set_stage_3": {
				"sequence": [
					{ "remove": { "component_groups": [ "loot:stage_0", "loot:stage_1", "loot:stage_2" ] } },
					{ "add":    { "component_groups": [ "loot:stage_3" ] } },
					{ "set_property": { "loot:stage": 3 } }
				]
			},

			"loot:on_hurt": {
				"sequence": [
					{ "remove": { "component_groups": [ "loot:hurt_cooldown" ] } },
					{ "set_property": { "loot:hurt": true } },
					{ "add":    { "component_groups": [ "loot:hurt_cooldown" ] } }
				]
			},
			"loot:end_hurt": {
				"sequence": [
					{ "set_property": { "loot:hurt": false } },
					{ "remove": { "component_groups": [ "loot:hurt_cooldown" ] } }
				]
			},

			"loot:lock_movement": {
				"add": { "component_groups": [ "loot:locked_move" ] }
			},
			"loot:unlock_movement": {
				"remove": { "component_groups": [ "loot:locked_move" ] }
			},

			"loot:admire_start": {
				"sequence": [
					{ "set_property": { "loot:lock_anim": 4 } },
					{ "set_property": { "loot:locked": true } }
				]
			},
			"loot:admire_stop": {
				"sequence": [
					{ "set_property": { "loot:lock_anim": 0 } },
					{ "set_property": { "loot:locked": false } }
				]
			}
		}
