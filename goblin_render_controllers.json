{
	"format_version": "1.10.0",
	"render_controllers": {
		"controller.render.goblin.skin": {
			"geometry": "geometry.default",
			"materials": [ { "*": "material.default" } ],
			"textures": [
				"variable.name >= 0 ? array.names[variable.name] : array.skins[variable.skin_index]"
			],
			"arrays": {
				"textures": {
					"array.names": [
						"texture.poppy", "texture.tristana", "texture.malvah",
						"texture.smug",  "texture.gobu",     "texture.jackie"
					],
					"array.skins": [
						"texture.skin0", "texture.skin1", "texture.skin2",
						"texture.skin3", "texture.skin4", "texture.skin5",
						"texture.skin6", "texture.skin7", "texture.skin8",
						"texture.skin9"
					]
				}
			}
		},

		"controller.render.goblin.eyes": {
			"geometry": "geometry.eyes",
			"materials": [ { "*": "material.default" } ],
			"textures": [
				"variable.name >= 0 ? array.names[variable.name] : array.eyes[variable.eye_index]"
			],
			"arrays": {
				"textures": {
					"array.names": [
						"texture.poppy", "texture.tristana", "texture.malvah",
						"texture.smug",  "texture.gobu",     "texture.jackie"
					],
					"array.eyes": [
						"texture.eye0", "texture.eye1", "texture.eye2",
						"texture.eye3", "texture.eye4", "texture.eye5",
						"texture.eye6", "texture.eye7", "texture.eye8",
						"texture.eye9"
					]
				}
			}
		},

		"controller.render.goblin.hair": {
			"geometry": "geometry.hair",
			"materials": [ { "*": "material.default" } ],
			"textures": [
				"variable.name >= 0 ? array.names[variable.name] : array.hairs[variable.hair_index]"
			],
			"arrays": {
				"textures": {
					"array.names": [
						"texture.poppy", "texture.tristana", "texture.malvah",
						"texture.smug",  "texture.gobu",     "texture.jackie"
					],
					"array.hairs": [
						"texture.hair0",  "texture.hair1",  "texture.hair2",  "texture.hair3",
						"texture.hair4",  "texture.hair5",  "texture.hair6",  "texture.hair7",
						"texture.hair8",  "texture.hair9",  "texture.hair10", "texture.hair11",
						"texture.hair12", "texture.hair13", "texture.hair14", "texture.hair15"
					]
				}
			}
		},

		"controller.render.goblin.cloth": {
			"geometry": "geometry.cloth",
			"materials": [ { "*": "material.default" } ],
			"textures": [
				"variable.name >= 0 ? array.names[variable.name] : array.outfits[variable.clothes_index]"
			],
			"arrays": {
				"textures": {
					"array.names": [
						"texture.poppy", "texture.tristana", "texture.malvah",
						"texture.smug",  "texture.gobu",     "texture.jackie"
					],
					"array.outfits": [
						"texture.cloth0", "texture.cloth1", "texture.cloth2",
						"texture.cloth3", "texture.cloth4", "texture.cloth5",
						"texture.cloth6", "texture.cloth7", "texture.cloth8",
						"texture.cloth9"
					]
				}
			}
		},

		"controller.render.goblin.weapons": {
			"geometry": "geometry.weapons",
			"materials": [ 
				{ "*": "material.default" },
				{ "rightItem": "variable.weapon_state == 2 ? material.offhand_blank : material.default" }
			],
			"textures": [
				"variable.weapon_state == 2 ? (variable.crossbow_phase > 0 ? array.weapon_textures[10] : array.weapon_textures[9]) : (variable.weapon_state == 3 ? array.weapon_textures[8] : (variable.weapon_state == 4 ? array.weapon_textures[variable.weapon_texture] : (variable.weapon_state == 0 ? array.weapon_textures[11] : array.weapon_textures[variable.weapon_texture])))"
			],
			"arrays": {
				"textures": {
					"array.weapon_textures": [
						"texture.sword",        "texture.sword_gold",
						"texture.axe",          "texture.axe_gold",
						"texture.pickaxe",      "texture.pickaxe_gold",
						"texture.spear",        "texture.spear_gold",
						"texture.mace",         "texture.bow_empty",
						"texture.bow_arrow",    "texture.blank"
					]
				}
			}
		},

		"controller.render.goblin.items": {
			"geometry": "geometry.items",
			"materials": [ { "*": "material.alphablend" } ],
			"textures": [
				"variable.locked && variable.lock_anim == 1 ? array.foods[variable.food_index] : (variable.locked && (variable.lock_anim == 0 || variable.lock_anim == 2 || variable.lock_anim == 3 || variable.lock_anim == 5) ? (variable.drink_index == 2 ? texture.mist : (variable.drink_index == 1 ? texture.exp : texture.honey)) : texture.blank)"
			],
			"part_visibility": [
				{ "*":           false },
				{ "apple":       "variable.locked && variable.lock_anim == 1 && (variable.food_index == 0 || variable.food_index == 3)" },
				{ "2D_a":        "variable.locked && variable.lock_anim == 1 && (variable.food_index == 0 || variable.food_index == 3)" },
				{ "bite_a1":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 0 || variable.food_index == 3)" },
				{ "bite_a2":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 0 || variable.food_index == 3)" },
				{ "bite_a3":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 0 || variable.food_index == 3)" },
				{ "bite_a4":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 0 || variable.food_index == 3)" },
				{ "melon":       "variable.locked && variable.lock_anim == 1 && (variable.food_index == 1 || variable.food_index == 4)" },
				{ "bite_m1":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 1 || variable.food_index == 4)" },
				{ "bite_m2":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 1 || variable.food_index == 4)" },
				{ "bite_m3":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 1 || variable.food_index == 4)" },
				{ "bite_m4":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 1 || variable.food_index == 4)" },
				{ "carrot":      "variable.locked && variable.lock_anim == 1 && (variable.food_index == 2 || variable.food_index == 5)" },
				{ "2D_c":        "variable.locked && variable.lock_anim == 1 && (variable.food_index == 2 || variable.food_index == 5)" },
				{ "bite_c1":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 2 || variable.food_index == 5)" },
				{ "bite_c2":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 2 || variable.food_index == 5)" },
				{ "bite_c3":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 2 || variable.food_index == 5)" },
				{ "bite_c4":     "variable.locked && variable.lock_anim == 1 && (variable.food_index == 2 || variable.food_index == 5)" },
				{ "bottle2":     "variable.locked && (variable.lock_anim == 0 || variable.lock_anim == 2 || variable.lock_anim == 3 || variable.lock_anim == 5)" },
				{ "cork":        "variable.locked && (variable.lock_anim == 0 || variable.lock_anim == 2 || variable.lock_anim == 3 || variable.lock_anim == 5)" },
				{ "bigLiquid":   "variable.locked && (variable.lock_anim == 0 || variable.lock_anim == 2 || variable.lock_anim == 3) && variable.drink_index == 0" },
				{ "smallLiquid": "variable.locked && (variable.lock_anim == 5) && variable.drink_index == 0" },
				{ "bigwater":    "variable.locked && (variable.lock_anim == 0 || variable.lock_anim == 2 || variable.lock_anim == 3) && variable.drink_index == 1" },
				{ "smallwater":  "variable.locked && (variable.lock_anim == 5) && variable.drink_index == 1" }
			],
			"arrays": {
				"textures": {
					"array.foods": [
						"texture.apple",        "texture.melon",
						"texture.carrot",       "texture.golden_apple",
						"texture.golden_melon", "texture.golden_carrot"
					]
				}
			}
		}
	}
}
